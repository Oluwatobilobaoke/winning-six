rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // This rule allows anyone with your Firestore database reference to view, edit,
    // and delete all data in your Firestore database. It is useful for getting
    // started, but it is configured to expire after 30 days because it
    // leaves your app open to attackers. At that time, all client
    // requests to your Firestore database will be denied.
    //
    // Make sure to write security rules for your app before that time, or else
    // all client requests to your Firestore database will be denied until you Update
    // your rules
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Players: Only authenticated users can write
    match /players/{playerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Seasons: read access only
    match /seasons/{seasonId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /matchdays/{matchdayId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /teams/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Games: Allow read to all logged in users
    match /games/{gameId} {
      allow read: if true;

      // Allow write only if user is authenticated and owns the game (if applicable)
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Default catch-all (DENY EVERYTHING ELSE)
    match /{document=**} {
      allow read, write: if false;
    }

  }
}